  "faqPage": {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Do you support bulk and private label orders?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Gratia Global handles bulk quantities and also provides customized packaging and private labeling to match your brand and market requirements."
        }
      },
      {
        "@type": "Question",
        "name": "Can we request product samples before ordering?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. We share product samples for approval so you can verify quality, texture, and specification before placing a final order."
        }
      },
      {
        "@type": "Question",
        "name": "Which countries do you currently export to?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Gratia Global exports across the Middle East, Europe, Southeast Asia, and beyond — serving 20+ countries including UAE, UK, Singapore, Germany, and Malaysia."
        }
      },
      {
        "@type": "Question",
        "name": "What quality certifications do you follow?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We maintain HACCP and ISO 22000:2018 standards. FSSAI, APEDA, and USDA Organic documentation support available."
        }
      },
      {
        "@type": "Question",
        "name": "What is your minimum order quantity for export?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "MOQ depends on product category and packaging format. Our team shares a clear MOQ and quotation during the inquiry stage."
        }
      },
      {
        "@type": "Question",
        "name": "How long does it take from confirmation to dispatch?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most orders are dispatched within the agreed lead time after sample approval and documentation confirmation. Exact timelines shared in the final quote."
        }
      },
      {
        "@type": "Question",
        "name": "Do you assist with export documentation and compliance?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Gratia Global supports complete export documentation including invoice, packing list, certificate of origin, and shipment compliance for smooth customs clearance."
        }
      }
    ]
  },
